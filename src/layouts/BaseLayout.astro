---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  currentSlug?: string;
}

const {
  title = 'Chasing the Bear',
  description = 'Notes on AI, software, and learning in public.',
  ogType = 'website',
  canonicalUrl = Astro.url.href,
  currentSlug,
} = Astro.props;

const siteUrl = 'https://chasingthebear.net';
const ogImage = `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Chasing the Bear" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Feeds -->
    <link rel="alternate" type="application/rss+xml" title="Chasing the Bear RSS Feed" href="/rss.xml" />

    <link rel="icon" type="image/png" href="/chasing-the-bear-transparent-background.png" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo">
          <img src="/chasing-the-bear-logo.png" alt="Chasing the Bear logo" class="site-logo-img" />
          Chasing the Bear
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
          <a href="/archive">Archive</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>

    <div class="page-wrapper">
      <Sidebar currentSlug={currentSlug} />
      <main>
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Chasing the Bear &mdash; <a href="https://github.com/zachsladecode/chasing-the-bear" target="_blank" rel="noopener">Source on GitHub</a></p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Component-scoped styles — see docs/architecture.md#styling */

  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-logo {
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .site-logo-img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .site-logo:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    gap: var(--space-6);
  }

  .site-nav a {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .page-wrapper {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: var(--space-16) var(--space-6);
    min-height: calc(100vh - 200px);
    display: flex;
    gap: var(--space-12);
    align-items: flex-start;
  }

  main {
    flex: 1;
    min-width: 0;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    position: sticky;
    bottom: 0;
    z-index: 100;
    background-color: var(--color-bg);
  }

  .site-footer .container {
    justify-content: center;
  }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .site-footer a {
    color: var(--color-text-muted);
  }

  .site-footer a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      padding: var(--space-12) var(--space-4);
      gap: 0;
    }
  }

  @media (max-width: 640px) {
    .site-nav {
      gap: var(--space-4);
    }

    .page-wrapper {
      padding: var(--space-8) var(--space-4);
    }
  }
</style>
