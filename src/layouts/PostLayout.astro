---
import BaseLayout from './BaseLayout.astro';
import TerminalHeader from '../components/TerminalHeader';

interface Props {
  title: string;
  date: string;
  category?: string;
  tags?: string[];
  body: string;
  summary?: string;
  author?: string;
  currentSlug?: string;
}

const { title, date, category, tags = [], body, summary, author, currentSlug } = Astro.props;

// Parse date parts directly to avoid UTC-to-local timezone shift on YYYY-MM-DD strings
const [year, month, day] = date.split('-').map(Number);
const formattedDate = new Date(year, month - 1, day).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const wordCount = body.trim().split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);
---

<BaseLayout title={`${title} — Chasing the Bear`} description={summary ?? title} currentSlug={currentSlug}>
  <article class="post">
    <header class="post-header">
      <a href="/blog" class="back-link">&larr; All posts</a>

      <!--
        SEO / accessibility: full header content stays in the DOM, visually hidden.
        TerminalHeader (aria-hidden) types it out character by character for sighted users.
        See docs/architecture.md#styling for the scoped-styles pattern.
      -->
      <div class="post-header-static" aria-hidden="false">
        <div class="post-meta">
          <time datetime={date}>{formattedDate}</time>
          <span class="meta-sep">&middot;</span>
          <span class="reading-time">{readingTime} min read</span>
          {author && (
            <>
              <span class="meta-sep">&middot;</span>
              <span class="post-author">{author}</span>
            </>
          )}
          {category && (
            <>
              <span class="meta-sep">&middot;</span>
              <span class="post-category">{category}</span>
            </>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
      </div>

      <TerminalHeader
        title={title}
        date={date}
        category={category ?? ''}
        client:load
      />

      {tags.length > 0 && (
        <ul class="post-tags" aria-label="Tags">
          {tags.map((tag) => (
            <li class="post-tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="post-body">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; All posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  /* Component-scoped styles — see docs/architecture.md#styling */

  .post {
    max-width: var(--max-width-prose);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: var(--space-12);
  }

  /* Static header: visually hidden but accessible to screen readers + SEO */
  .post-header-static {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .post-author {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .post-meta time,
  .reading-time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .meta-sep {
    color: var(--color-border);
  }

  .post-category {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .post-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-top: var(--space-6);
  }

  .post-tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-mono);
  }

  /* TerminalHeader global styles */
  :global(.th-header) {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    line-height: var(--leading-snug);
  }

  :global(.th-line) {
    margin-bottom: var(--space-2);
  }

  :global(.th-prompt) {
    color: var(--color-accent);
    user-select: none;
  }

  :global(.th-title) {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
  }

  :global(.th-meta) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  :global(.th-cursor) {
    display: inline-block;
    width: 0.55em;
    height: 1.1em;
    background: var(--color-accent);
    vertical-align: text-bottom;
    margin-left: 2px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  :global(.th-header--done .th-title) {
    display: block;
  }

  /* Prose styles for rendered Markdown */
  .post-body {
    line-height: var(--leading-relaxed);
  }

  .post-body :global(h2) {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .post-body :global(h3) {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .post-body :global(h4) {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-8) 0;
    background-color: var(--color-surface);
    border-radius: 0 6px 6px 0;
  }

  .post-body :global(blockquote p) {
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0;
  }

  .post-body :global(code):not(:global(pre code)) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  .post-body :global(pre) {
    margin: var(--space-6) 0;
    border-radius: 8px;
    font-size: var(--text-sm);
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-12) 0;
  }

  .post-body :global(img) {
    border-radius: 6px;
    margin: var(--space-8) 0;
  }

  .post-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    :global(.th-title) {
      font-size: var(--text-3xl);
    }
  }
</style>
