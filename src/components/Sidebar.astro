---
import { getCollection } from 'astro:content';
import DirTree from './DirTree';
import { buildTree } from '../lib/buildTree';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const posts = await getCollection('blog', ({ data }) => !data.draft);
const tree = buildTree(posts);
---

<aside class="sidebar">
  <DirTree tree={tree} currentSlug={currentSlug} client:load />
</aside>

<style>
  /* Component-scoped styles — see docs/architecture.md#styling */

  .sidebar {
    width: var(--sidebar-width, 240px);
    flex-shrink: 0;
  }

  /* --- DirTree styles (global because Preact renders outside Astro scope) --- */
  :global(.sidebar-toggle) {
    display: none;
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 60;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-size: var(--text-base);
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
    cursor: pointer;
    font-family: var(--font-mono);
  }

  :global(.dir-tree) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    overflow-y: auto;
  }

  :global(.tree-root) {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: var(--space-3);
    letter-spacing: 0.02em;
  }

  :global(.tree-root-list),
  :global(.tree-children) {
    list-style: none;
    padding-left: var(--space-4);
  }

  :global(.tree-root-list) {
    padding-left: 0;
  }

  :global(.tree-folder) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-1) 0;
    cursor: pointer;
    width: 100%;
    text-align: left;
    transition: color 0.15s ease;
  }

  :global(.tree-folder:hover) {
    color: var(--color-text);
  }

  :global(.tree-folder--category) {
    font-weight: 600;
    color: var(--color-text);
  }

  :global(.tree-post) {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-1) 0;
    transition: color 0.15s ease;
    line-height: var(--leading-snug);
  }

  :global(.tree-post:hover) {
    color: var(--color-text);
    text-decoration: none;
  }

  :global(.tree-post--active) {
    color: var(--color-accent);
  }

  :global(.tree-post--active:hover) {
    color: var(--color-accent);
  }

  :global(.tree-icon) {
    flex-shrink: 0;
    font-size: var(--text-xs);
    width: 0.8em;
    display: inline-block;
    color: var(--color-text-muted);
  }

  :global(.tree-post--active .tree-icon) {
    color: var(--color-accent);
  }

  :global(.tree-label) {
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
    }

    :global(.sidebar-toggle) {
      display: block;
    }

    :global(.dir-tree) {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 50;
      background: var(--color-bg);
      padding: var(--space-16) var(--space-6) var(--space-6);
      overflow-y: auto;
      max-height: 100vh;
    }

    :global(.dir-tree--open) {
      display: block;
    }

    @media (prefers-reduced-motion: no-preference) {
      :global(.dir-tree--open) {
        animation: slideIn 0.2s ease;
      }

      @keyframes slideIn {
        from { transform: translateX(-100%); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
      }
    }
  }
</style>
