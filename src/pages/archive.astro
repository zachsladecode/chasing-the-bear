---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Derive year from ISO date string to avoid UTC-to-local timezone shift
// (same pattern as PostLayout.astro — see docs/architecture.md#styling)
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.toISOString().split('T')[0].split('-')[0];
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Archive — Chasing the Bear" description="All posts on Chasing the Bear, grouped by year.">
  <section class="archive">
    <h1 class="archive-title">Archive</h1>

    {years.map((year) => (
      <div class="year-group">
        <h2 class="year-heading">{year}</h2>
        <ul class="post-list">
          {postsByYear[year].map((post) => {
            const [y, m, d] = post.data.date.toISOString().split('T')[0].split('-').map(Number);
            const label = new Date(y, m - 1, d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            return (
              <li class="post-entry">
                <time class="post-date" datetime={post.data.date.toISOString().split('T')[0]}>{label}</time>
                <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  /* Component-scoped styles — see docs/architecture.md#styling */

  .archive {
    max-width: var(--max-width-prose);
  }

  .archive-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-12);
  }

  .year-group {
    margin-bottom: var(--space-12);
  }

  .year-heading {
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-entry {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    min-width: 4.5rem;
    flex-shrink: 0;
  }

  .post-title {
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
    line-height: var(--leading-snug);
  }

  .post-title:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .archive-title {
      font-size: var(--text-3xl);
    }
  }
</style>
